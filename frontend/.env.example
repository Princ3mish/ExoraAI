# ─── Backend API URL ──────────────────────────────────
# Local: http://localhost:4000
# Production: https://your-render-service.onrender.com
VITE_API_URL=http://localhost:4000

# ─── Telegram Bot ─────────────────────────────────────
# Your bot username WITHOUT the @ symbol
# Example: meetingagent_Exora_bot
VITE_TELEGRAM_BOT_USERNAME=your_bot_username_bot

# ─── Stripe ───────────────────────────────────────────
# Publishable key from stripe.com/developers
# Starts with pk_test_ (test) or pk_live_ (production)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_
