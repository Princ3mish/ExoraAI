// Phase R1: Extended schema — new Meeting/Participant fields + BotSession + VoiceCallLog
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum MeetingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum ParticipantStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id                   String         @id @default(uuid())
  email                String         @unique
  name                 String?
  phoneNumber          String?
  password             String
  role                 Role           @default(USER)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  // Phase S1 — Telegram account linking
  telegramId           String?        @unique
  telegramLinked       Boolean        @default(false)
  telegramLinkToken    String?        @unique
  telegramLinkExpiry   DateTime?

  // Phase S1 — Billing / credits
  credits              Int            @default(50)
  plan                 String         @default("free")

  organizedMeetings    Meeting[]      @relation("MeetingOrganizer")
  participations       Participant[]
  availabilities       Availability[]
  events               AIEvent[]      @relation("UserEvents")
  botSessions          BotSession[]

  // Phase S2 — UserContact: meetings I organized link me to their participants
  contactsOwned        UserContact[]  @relation("ContactOwner")
  contactEntries       UserContact[]  @relation("ContactUser")

  // Phase S4 — Credit transaction audit trail
  transactions         CreditTransaction[]
}

model Meeting {
  id                 String        @id @default(uuid())
  title              String
  description        String?
  durationMins       Int?
  startTime          DateTime
  endTime            DateTime
  status             MeetingStatus @default(PENDING)
  organizerId        String
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // Phase R1 — agent orchestration fields
  agendaTopics       String[]
  voiceCallStatus    String        @default("pending")
  botThreadId        String?
  confirmationStatus String        @default("unconfirmed")

  organizer          User          @relation("MeetingOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  participants       Participant[]
  aiResults          AIResult[]
  events             AIEvent[]     @relation("MeetingEvents")
  botSessions        BotSession[]
  voiceCallLogs      VoiceCallLog[]

  @@index([organizerId])
  @@index([voiceCallStatus])
  @@index([startTime])
}

model Participant {
  userId        String
  meetingId     String
  status        ParticipantStatus @default(PENDING)
  joinedAt      DateTime          @default(now())

  // Phase R1 — voice agent fields
  phoneNumber   String?
  voiceResponse String?

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  meeting       Meeting           @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  voiceCallLogs VoiceCallLog[]

  @@id([meetingId, userId])
  @@index([userId])
}

model Availability {
  id         String   @id @default(uuid())
  userId     String
  startTime  DateTime
  endTime    DateTime

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AIResult {
  id         String   @id @default(uuid())
  meetingId  String
  taskType   String
  payload    Json
  createdAt  DateTime @default(now())

  meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

model AIEvent {
  id        String   @id @default(cuid())
  type      String
  message   String
  status    String   @default("success")
  meetingId String?
  userId    String?
  metadata  Json?
  createdAt DateTime @default(now())

  meeting   Meeting? @relation("MeetingEvents", fields: [meetingId], references: [id], onDelete: SetNull)
  user      User?    @relation("UserEvents", fields: [userId], references: [id], onDelete: SetNull)

  @@index([meetingId])
  @@index([userId])
  @@index([createdAt])
}

// Phase R1 — Telegram bot conversation session
model BotSession {
  id         String   @id @default(uuid())
  telegramId String
  intent     String?
  slots      Json     @default("{}")
  status     String   @default("active")
  meetingId  String?
  userId     String?
  createdAt  DateTime @default(now())

  meeting    Meeting? @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([telegramId])
  @@index([meetingId])
  @@index([userId])
}

// Phase R1 — Outbound voice call log (Twilio or simulated)
// References the composite-PK Participant via two FK columns.
model VoiceCallLog {
  id                  String   @id @default(uuid())
  participantUserId   String
  participantMeetingId String
  meetingId           String
  callSid             String?
  transcript          String?
  outcome             String   @default("pending")
  agendaExtracted     String[]
  duration            Int?
  calledAt            DateTime @default(now())

  participant         Participant @relation(fields: [participantMeetingId, participantUserId], references: [meetingId, userId], onDelete: Cascade)
  meeting             Meeting     @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([participantUserId])
  @@index([participantMeetingId])
}

// Phase S2 — UserContact: per-user address book built from meeting organizer↔participant links
model UserContact {
  id          String   @id @default(uuid())
  ownerId     String
  contactId   String
  createdAt   DateTime @default(now())

  owner       User     @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  contact     User     @relation("ContactUser",  fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([ownerId, contactId])
  @@index([ownerId])
  @@index([contactId])
}

// Phase S4 — Credit purchase + deduction audit trail
model CreditTransaction {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  amount          Int
  type            String   // 'purchase' | 'deduction'
  reason          String   // 'credit_purchase' | 'meeting_created' | 'voice_call_initiated'
  stripeSessionId String?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
