# ─── Database ─────────────────────────────────────────
# Local: postgresql://postgres:password@localhost:5432/exora
# Render: automatically provided when you add Postgres
DATABASE_URL=postgresql://user:password@localhost:5432/exora

# ─── Server ───────────────────────────────────────────
PORT=4000
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
NODE_ENV=development

# ─── Public Server URL ────────────────────────────────
# Local dev: your ngrok HTTPS URL (ngrok http 4000)
# Production: your Render service URL
SERVER_URL=https://your-server-url.com

# ─── Allowed Frontend Origins (CORS) ─────────────────
# Local: http://localhost:5173
# Production: https://your-vercel-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# ─── Telegram Bot ─────────────────────────────────────
# 1. Open Telegram and message @BotFather
# 2. Send /newbot and follow the steps
# 3. Copy the token (format: 1234567890:ABCdef...)
TELEGRAM_BOT_TOKEN=
# Any random string you choose for webhook security
TELEGRAM_WEBHOOK_SECRET=any-random-string-you-choose

# ─── Groq AI — Primary LLM ────────────────────────────
# Free tier: 1000 requests/day
# Get key from: console.groq.com
GROQ_API_KEY=

# ─── OpenRouter — Fallback LLM ────────────────────────
# Free models available
# Get key from: openrouter.ai
OPENROUTER_API_KEY=

# ─── Vapi — Voice Agent ───────────────────────────────
# 1. Sign up at dashboard.vapi.ai
# 2. Create an assistant with your system prompt
# 3. Get a free US phone number
# 4. Copy the three values below
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=

# ─── Resend — Email Service ───────────────────────────
# Free tier: 3000 emails/month
# Get key from: resend.com
RESEND_API_KEY=

# ─── Stripe — Payments ────────────────────────────────
# Get from: stripe.com/developers → API Keys
STRIPE_SECRET_KEY=
# Get from: stripe.com/developers → Webhooks
STRIPE_WEBHOOK_SECRET=
# Get from: stripe.com → Products → your product price
STRIPE_PRICE_ID=

# ─── Initial Admin User ───────────────────────────────
# Created automatically when you run: npx prisma db seed
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@exora.ai
ADMIN_PASSWORD=changeme123
